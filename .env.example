# ─── App ─────────────────────────────────────────────────
NODE_ENV=production

# ─── Binance ───────────────────────────────────────────────
# Use 'mainnet' for real trading, 'testnet' for testing
BINANCE_ENV=mainnet
BINANCE_API_KEY=your_mainnet_api_key
BINANCE_SECRET_KEY=your_mainnet_secret_key
# NOTE: BINANCE_BASE_URL, BINANCE_WS_BASE, and BINANCE_FUTURES_URL are
# automatically derived from BINANCE_ENV in backend/config/env.js — do NOT set them here.

# ─── Taapi.io ──────────────────────────────────────────────
TAAPI_SECRET=your_taapi_secret_key

# ─── Telegram ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# ─── Database ──────────────────────────────────────────────
# PRODUCTION (Docker): use Docker service names as hostnames
MONGODB_URI=mongodb://mongodb:27017/novapulse
REDIS_URL=redis://redis:6379
# LOCAL DEV (non-Docker): uncomment these and comment the above
# MONGODB_URI=mongodb://localhost:27017/novapulse
# REDIS_URL=redis://localhost:6379

# ─── ML Service ────────────────────────────────────────────
# PRODUCTION (Docker): use Docker service name
ML_SERVICE_URL=http://ml-service:5001
ML_PORT=5001
# LOCAL DEV: uncomment this and comment the above
# ML_SERVICE_URL=http://localhost:5001

# ─── Auth & Security ────────────────────────────────────────
DASHBOARD_PASSWORD=your_strong_dashboard_password
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_random_256bit_secret
# Domain-based TLS setup:
# CORS_ORIGIN=https://trade.yourdomain.com
# Direct IP access (no TLS/Certbot required):
CORS_ORIGIN=http://YOUR_VPS_IP

# ─── Risk Config ───────────────────────────────────────────
MAX_DAILY_DRAWDOWN=2
MAX_OPEN_POSITIONS=3
MAX_CAPITAL_PER_TRADE=20
ML_CONFIDENCE_THRESHOLD=0.72
TAKE_PROFIT_PCT=1.0
STOP_LOSS_PCT=0.5
